# Copie para .env e ajuste. Variáveis EXPO_PUBLIC_* ficam disponíveis no app.

# URL base da API.
# - Web / emulador no mesmo PC: http://localhost:8000/api/v1
# - Dispositivo físico: use o IP da sua máquina na rede local e rode o backend
#   com `uvicorn app.main:app --reload --host 0.0.0.0`.
#   Ex.: http://192.168.0.10:8000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
