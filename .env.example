# Copie este arquivo para .env e ajuste os valores.
# O .env NÃO é versionado (ver .gitignore).

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=xpress_code

# API
API_V1_PREFIX=/api/v1

# CORS — origens de clientes NAVEGADOR (SPA web e Expo Web), separadas por vírgula.
# Portas: 8081 (Expo Web), 5173 (Vite legado), 19006 (Expo Web alternativo).
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173,http://127.0.0.1:5173,http://localhost:19006

# JWT
JWT_SECRET=troque-este-valor-por-um-segredo-forte
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# WhatsApp Cloud API (Meta). Opcional — sem META_ACCESS_TOKEN o /whatsapp/status
# responde "não configurado" e o webhook rejeita tudo.
#
# Como obter:
#   1. Crie um app na Meta for Developers (developers.facebook.com) → produto "WhatsApp".
#   2. Em "API Setup", copie o Phone Number ID e o Access Token (de teste ou permanente).
#   3. Em "Configuration", cadastre o webhook apontando para a URL pública da API
#      (use ngrok em dev: ngrok http 8000) e cole o mesmo VERIFY_TOKEN abaixo.
#   4. App Secret está em "App Settings → Basic".
META_GRAPH_API_VERSION=v21.0
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=troque-este-valor-por-um-segredo-forte
