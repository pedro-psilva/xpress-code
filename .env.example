# Copie este arquivo para .env e ajuste os valores.
# O .env NÃO é versionado (ver .gitignore).

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=xpress_code

# API
API_V1_PREFIX=/api/v1

# CORS — origens de clientes NAVEGADOR (SPA web e Expo Web), separadas por vírgula.
# App React Native nativo NÃO precisa estar aqui (não sofre CORS).
# Portas:
#   8081  → Expo Web (padrão, `npm run web`)
#   5173  → Vite legado (frontend/)
#   19006 → Expo Web alternativo (algumas versões)
# Para dev mobile, rode a API com: uvicorn app.main:app --reload --host 0.0.0.0
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173,http://127.0.0.1:5173,http://localhost:19006

# JWT (usado a partir do M2 — Bônus A/B)
JWT_SECRET=troque-este-valor-por-um-segredo-forte
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# WhatsApp / Evolution API (opcional — só ativa se EVOLUTION_API_KEY estiver
# definida e o container estiver no ar via `docker compose --profile whatsapp up -d`).
# A URL do webhook precisa ser alcançável a partir do container do Evolution.
# No Docker Desktop (Windows/Mac), use host.docker.internal; no Linux, o IP do host.
EVOLUTION_API_KEY=troque-este-valor-por-um-segredo-forte
EVOLUTION_POSTGRES_PASSWORD=troque-este-valor
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=${EVOLUTION_API_KEY}
WHATSAPP_INSTANCE_NAME=xpress
WHATSAPP_WEBHOOK_URL=http://host.docker.internal:8000/api/v1/whatsapp/webhook
